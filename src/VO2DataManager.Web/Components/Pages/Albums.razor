@page "/albums"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using Microsoft.EntityFrameworkCore
@using SharedServices.Models.AiData
@inject IDbContextFactory<AppDbContextAiData> DbFactory
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Alba — VO2 Data Manager</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-vinyl"></i> Alba</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-success" @onclick="ExportCsvAsync">
            <i class="bi bi-download me-1"></i>Export CSV
        </button>
        <button class="btn btn-sm btn-primary" @onclick="ShowAddForm">
            <i class="bi bi-plus-lg me-1"></i>Přidat
        </button>
    </div>
</div>

<ConfirmDialog @ref="_confirmDialog" />

<!-- Add / Edit form -->
@if (_showForm)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-@(_editId.HasValue ? "pencil" : "plus-circle") text-accent"></i>
                @(_editId.HasValue ? "Upravit album" : "Nové album")
            </span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="HideForm">Zrušit</button>
        </div>
        <div class="p-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Název</label>
                    <input class="form-control form-control-sm" @bind="_form.Title" placeholder="Název alba" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">Interpret</label>
                    <input class="form-control form-control-sm" @bind="_form.ArtistDisplay" placeholder="Interpret" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Rok vydání</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ReleaseYear" placeholder="Rok" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Skóre</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ConfidenceScore" placeholder="Skóre" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">Label</label>
                    <input class="form-control form-control-sm" @bind="_form.Label" placeholder="Label" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">GuidId</label>
                    <input class="form-control form-control-sm" @bind="_form.GuidId" placeholder="GUID" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="mt-2 text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>@_error</div>
            }
            <div class="mt-3">
                <button class="btn btn-success btn-sm" @onclick="SaveAsync">
                    <i class="bi bi-check-lg me-1"></i>Uložit
                </button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Načítám alba…</span>
    </div>
}
else
{
    <UiSearchBar @bind-Value="_search" Placeholder="Hledat album nebo interpreta…"
                 Count="_total" CountLabel="alb"
                 OnSearch="ResetAndLoad" />

    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-vinyl text-accent"></i>
                Databáze alb
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Název</th>
                        <th>Interpret</th>
                        <th class="text-center">Rok</th>
                        <th class="text-center">Skóre</th>
                        <th>Label</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_albums.Any())
                    {
                        <tr><td colspan="6" class="text-muted text-center py-4">Žádné záznamy.</td></tr>
                    }
                    @foreach (var a in _albums)
                    {
                        <tr>
                            <td class="fw-semibold"><a href="/albums/@a.Id" class="text-decoration-none">@a.Title</a></td>
                            <td class="text-muted small">@a.ArtistDisplay</td>
                            <td class="text-center text-muted small">@a.ReleaseYear</td>
                            <td class="text-center"><span class="badge bg-secondary">@a.ConfidenceScore</span></td>
                            <td class="text-muted small">@a.Label</td>
                            <td class="text-end">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEditForm(a)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(a.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-3 py-2 border-top border-opacity-10">
            <Paginator TotalItems="_total" PageSize="_pageSize" CurrentPage="_page"
                       OnPageChanged="async p => { _page = p; await LoadAsync(); }" />
        </div>
    </div>
}

@code {
    private ConfirmDialog _confirmDialog = default!;
    private int _pendingDeleteId;

    private bool _loading = true;
    private string _search = string.Empty;
    private List<Album> _albums = new();
    private int _page = 1;
    private const int _pageSize = 50;
    private int _total = 0;

    private bool _showForm = false;
    private int? _editId = null;
    private string? _error = null;
    private AlbumFormModel _form = new();

    private class AlbumFormModel
    {
        public string? Title { get; set; }
        public string? ArtistDisplay { get; set; }
        public int? ReleaseYear { get; set; }
        public int? ConfidenceScore { get; set; }
        public string? Label { get; set; }
        public string? GuidId { get; set; }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Albums.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
            query = query.Where(a =>
                (a.Title != null && a.Title.Contains(_search)) ||
                (a.ArtistDisplay != null && a.ArtistDisplay.Contains(_search)));
        _total = await query.CountAsync();
        _albums = await query
            .OrderBy(a => a.ArtistDisplay).ThenBy(a => a.ReleaseYear)
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToListAsync();
        _loading = false;
    }

    private async Task ResetAndLoad() { _page = 1; await LoadAsync(); }

    private void ShowAddForm() { _editId = null; _form = new(); _error = null; _showForm = true; }

    private void ShowEditForm(Album a)
    {
        _editId = a.Id;
        _form = new AlbumFormModel
        {
            Title = a.Title, ArtistDisplay = a.ArtistDisplay,
            ReleaseYear = a.ReleaseYear, ConfidenceScore = a.ConfidenceScore,
            Label = a.Label, GuidId = a.GuidId
        };
        _error = null;
        _showForm = true;
    }

    private void HideForm() { _showForm = false; _editId = null; _error = null; }

    private async Task SaveAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (_editId.HasValue)
            {
                var existing = await db.Albums.FindAsync(_editId.Value);
                if (existing != null)
                {
                    existing.Title = _form.Title; existing.ArtistDisplay = _form.ArtistDisplay;
                    existing.ReleaseYear = _form.ReleaseYear; existing.ConfidenceScore = _form.ConfidenceScore;
                    existing.Label = _form.Label; existing.GuidId = _form.GuidId;
                    existing.UpdatedAt = DateTime.UtcNow;
                }
            }
            else
            {
                db.Albums.Add(new Album
                {
                    Title = _form.Title, ArtistDisplay = _form.ArtistDisplay,
                    ReleaseYear = _form.ReleaseYear, ConfidenceScore = _form.ConfidenceScore,
                    Label = _form.Label, GuidId = _form.GuidId,
                    CreatedAt = DateTime.UtcNow, UpdatedAt = DateTime.UtcNow
                });
            }
            await db.SaveChangesAsync();
            Toast.ShowSuccess("Uloženo", _editId.HasValue ? "Album bylo upraveno." : "Album bylo přidáno.");
            HideForm();
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; Toast.ShowError("Chyba", ex.Message); }
    }

    private async Task ConfirmDelete(int id)
    {
        _pendingDeleteId = id;
        if (await _confirmDialog.ShowAsync("Smazat album", "Opravdu chcete smazat toto album? Tato akce je nevratná."))
            await DeleteAsync(_pendingDeleteId);
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Albums.FindAsync(id);
            if (existing != null) { db.Remove(existing); await db.SaveChangesAsync(); }
            Toast.ShowSuccess("Smazáno", "Album bylo odstraněno.");
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; Toast.ShowError("Chyba", ex.Message); }
    }

    private async Task ExportCsvAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var all = await db.Albums.OrderBy(a => a.ArtistDisplay).ThenBy(a => a.ReleaseYear).ToListAsync();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Název,Interpret,Rok vydání,Skóre,Label");
        foreach (var a in all)
            sb.AppendLine($"\"{a.Title?.Replace("\"", "\"\"")}\",\"{a.ArtistDisplay?.Replace("\"", "\"\"")}\",{a.ReleaseYear},{a.ConfidenceScore},\"{a.Label?.Replace("\"", "\"\"")}\"");
        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        await JS.InvokeVoidAsync("downloadBase64File", "alba.csv", "text/csv", Convert.ToBase64String(bytes));
    }
}
