@page "/albums"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using Microsoft.EntityFrameworkCore
@using SharedServices.Models.AiData
@inject IDbContextFactory<AppDbContextAiData> DbFactory
@inject ToastService Toast

<PageTitle>Alba — VO2 Data Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="m-0"><i class="bi bi-vinyl me-2"></i>Alba</h4>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm">
        <i class="bi bi-plus-lg me-1"></i>Přidat
    </button>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger alert-dismissible" role="alert">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

@if (_showForm)
{
    <div class="card mb-3">
        <div class="card-header">
            <strong>@(_editId.HasValue ? "Upravit album" : "Nové album")</strong>
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label small">Název</label>
                    <input class="form-control form-control-sm" @bind="_form.Title" placeholder="Název alba" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Interpret</label>
                    <input class="form-control form-control-sm" @bind="_form.ArtistDisplay" placeholder="Interpret" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Rok vydání</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ReleaseYear" placeholder="Rok" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Skóre</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ConfidenceScore" placeholder="Skóre" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Label</label>
                    <input class="form-control form-control-sm" @bind="_form.Label" placeholder="Label" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">GuidId</label>
                    <input class="form-control form-control-sm" @bind="_form.GuidId" placeholder="GUID" />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success btn-sm" @onclick="SaveAsync">
                    <i class="bi bi-check-lg me-1"></i>Uložit
                </button>
                <button class="btn btn-secondary btn-sm" @onclick="HideForm">Zrušit</button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else
{
    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <input class="form-control form-control-sm" placeholder="Hledat album nebo interpreta…"
                   @bind="_search" @bind:event="oninput" @bind:after="OnSearchChanged" />
        </div>
        <div class="col-auto">
            <span class="badge bg-secondary">@_total alb</span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead class="table-secondary">
                <tr>
                    <th>Název</th>
                    <th>Interpret</th>
                    <th>Rok vydání</th>
                    <th>Skóre</th>
                    <th>Label</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in _albums)
                {
                    <tr>
                        <td class="fw-semibold">@a.Title</td>
                        <td class="text-muted">@a.ArtistDisplay</td>
                        <td class="text-muted small">@a.ReleaseYear</td>
                        <td class="text-muted small">@a.ConfidenceScore</td>
                        <td class="text-muted small">@a.Label</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" title="Upravit"
                                    @onclick="() => ShowEditForm(a)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-danger btn-sm" title="Smazat"
                                    @onclick="() => DeleteAsync(a.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_page == 0)" @onclick="PrevPage">← Předchozí</button>
        <span class="small text-muted">Strana @(_page + 1) (celkem @_total)</span>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_albums.Count < _pageSize)" @onclick="NextPage">Další →</button>
    </div>

    @if (!_albums.Any())
    {
        <p class="text-muted text-center mt-3">Žádné záznamy.</p>
    }
}

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private List<Album> _albums = new();
    private int _page = 0;
    private const int _pageSize = 50;
    private int _total = 0;

    private bool _showForm = false;
    private int? _editId = null;
    private string? _error = null;

    private AlbumFormModel _form = new();

    private class AlbumFormModel
    {
        public string? Title { get; set; }
        public string? ArtistDisplay { get; set; }
        public int? ReleaseYear { get; set; }
        public int? ConfidenceScore { get; set; }
        public string? Label { get; set; }
        public string? GuidId { get; set; }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Albums.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
            query = query.Where(a =>
                (a.Title != null && a.Title.Contains(_search)) ||
                (a.ArtistDisplay != null && a.ArtistDisplay.Contains(_search)));
        _total = await query.CountAsync();
        _albums = await query
            .OrderBy(a => a.ArtistDisplay).ThenBy(a => a.ReleaseYear)
            .Skip(_page * _pageSize)
            .Take(_pageSize)
            .ToListAsync();
        _loading = false;
    }

    private void ShowAddForm()
    {
        _editId = null;
        _form = new AlbumFormModel();
        _error = null;
        _showForm = true;
    }

    private void ShowEditForm(Album a)
    {
        _editId = a.Id;
        _form = new AlbumFormModel
        {
            Title = a.Title,
            ArtistDisplay = a.ArtistDisplay,
            ReleaseYear = a.ReleaseYear,
            ConfidenceScore = a.ConfidenceScore,
            Label = a.Label,
            GuidId = a.GuidId
        };
        _error = null;
        _showForm = true;
    }

    private void HideForm()
    {
        _showForm = false;
        _editId = null;
        _error = null;
    }

    private async Task SaveAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (_editId.HasValue)
            {
                var existing = await db.Albums.FindAsync(_editId.Value);
                if (existing != null)
                {
                    existing.Title = _form.Title;
                    existing.ArtistDisplay = _form.ArtistDisplay;
                    existing.ReleaseYear = _form.ReleaseYear;
                    existing.ConfidenceScore = _form.ConfidenceScore;
                    existing.Label = _form.Label;
                    existing.GuidId = _form.GuidId;
                    existing.UpdatedAt = DateTime.UtcNow;
                }
            }
            else
            {
                var album = new Album
                {
                    Title = _form.Title,
                    ArtistDisplay = _form.ArtistDisplay,
                    ReleaseYear = _form.ReleaseYear,
                    ConfidenceScore = _form.ConfidenceScore,
                    Label = _form.Label,
                    GuidId = _form.GuidId,
                    CreatedAt = DateTime.UtcNow,
                    UpdatedAt = DateTime.UtcNow
                };
                db.Albums.Add(album);
            }
            await db.SaveChangesAsync();
            Toast.ShowSuccess("Uloženo", _editId.HasValue ? "Album bylo úspěšně upraveno." : "Album bylo úspěšně přidáno.");
            HideForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Chyba", $"Nepodařilo se uložit: {ex.Message}");
        }
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Albums.FindAsync(id);
            if (existing != null)
            {
                db.Remove(existing);
                await db.SaveChangesAsync();
                Toast.ShowSuccess("Smazáno", "Album bylo úspěšně smazáno.");
            }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Chyba", $"Nepodařilo se smazat: {ex.Message}");
        }
    }

    private async Task OnSearchChanged()
    {
        _page = 0;
        await LoadAsync();
    }

    private async Task PrevPage() { if (_page > 0) { _page--; await LoadAsync(); } }
    private async Task NextPage() { _page++; await LoadAsync(); }
}
