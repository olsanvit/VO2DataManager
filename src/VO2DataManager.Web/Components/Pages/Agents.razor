@page "/agents"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContextAiData> DbFactory
@implements IDisposable

<PageTitle>Agenti — VO2 Data Manager</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-robot me-2"></i>Agenti</h3>
    <div class="d-flex gap-2 align-items-center">
        <span class="text-muted small">
            <i class="bi bi-arrow-clockwise me-1"></i>
            Auto-refresh za @_refreshCountdown s
        </span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshNow">
            <i class="bi bi-arrow-clockwise me-1"></i>Obnovit
        </button>
    </div>
</div>

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Načítám agenty…</span>
    </div>
}
else
{
    <!-- Stats bar -->
    <div class="row g-3 mb-4 ui-anim-fade-up">
        <div class="col-4 col-md-2">
            <div class="ui-panel text-center p-3" style="cursor:pointer" @onclick='() => SetFilter("OK")'>
                <div class="fs-4 fw-bold text-success">@_agents.Count(a => a.Status == "ok")</div>
                <div class="text-muted small">OK</div>
            </div>
        </div>
        <div class="col-4 col-md-2">
            <div class="ui-panel text-center p-3" style="cursor:pointer" @onclick='() => SetFilter("Chyba")'>
                <div class="fs-4 fw-bold text-danger">@_agents.Count(a => a.Status != null && a.Status.Contains("error"))</div>
                <div class="text-muted small">Chyba</div>
            </div>
        </div>
        <div class="col-4 col-md-2">
            <div class="ui-panel text-center p-3" style="cursor:pointer" @onclick='() => SetFilter("Blokováni")'>
                <div class="fs-4 fw-bold text-warning">@_agents.Count(a => a.Status != null && a.Status.Contains("blocked"))</div>
                <div class="text-muted small">Blokováni</div>
            </div>
        </div>
        <div class="col-4 col-md-2">
            <div class="ui-panel text-center p-3" style="cursor:pointer" @onclick='() => SetFilter("Bez dat")'>
                <div class="fs-4 fw-bold text-secondary">@_agents.Count(a => a.Status == null)</div>
                <div class="text-muted small">Bez dat</div>
            </div>
        </div>
        <div class="col-4 col-md-2">
            <div class="ui-panel text-center p-3" style="cursor:pointer" @onclick='() => SetFilter("Po termínu")'>
                <div class="fs-4 fw-bold text-danger">@_agents.Count(a => IsOverdue(a))</div>
                <div class="text-muted small">Po termínu</div>
            </div>
        </div>
        <div class="col-4 col-md-2">
            <div class="ui-panel text-center p-3" style="cursor:pointer" @onclick='() => SetFilter("Vše")'>
                <div class="fs-4 fw-bold text-accent">@_agents.Count</div>
                <div class="text-muted small">Celkem</div>
            </div>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="ui-panel ui-anim-fade-up mb-3 p-3">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="text-muted small me-1">Filtr:</span>
            @foreach (var f in _filters)
            {
                <button class="btn btn-sm @(f == _activeFilter ? "btn-primary" : "btn-outline-secondary")"
                        @onclick="() => SetFilter(f)">@f</button>
            }
            <div class="form-check form-switch ms-2 mb-0">
                <input class="form-check-input" type="checkbox" id="showInactive" @bind="_showInactive" />
                <label class="form-check-label text-muted small" for="showInactive">Zobrazit deaktivované</label>
            </div>
            <div class="ms-auto">
                <input class="form-control form-control-sm" style="width:220px"
                       @bind="_search" @bind:event="oninput" placeholder="Hledat agenta…" />
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-robot text-accent"></i>
                Přehled agentů (@FilteredAgents.Count())
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Agent</th>
                        <th>Typ</th>
                        <th class="text-center">Stav</th>
                        <th>Naposledy</th>
                        <th>Příště</th>
                        <th class="text-center">Zpoždění</th>
                        <th>Prompt</th>
                        <th>Highlights</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!FilteredAgents.Any())
                    {
                        <tr><td colspan="8" class="text-muted text-center py-4">Žádné záznamy.</td></tr>
                    }
                    @foreach (var a in FilteredAgents)
                    {
                        var overdue = IsOverdue(a);
                        var overdueH = OverdueHours(a);
                        <tr class="@(!a.IsActive ? "opacity-50" : overdue && overdueH > 48 ? "table-danger" : overdue ? "table-warning" : "")">
                            <td>
                                <a href="/agents/@Uri.EscapeDataString(a.AgentName)" class="fw-semibold text-decoration-none">
                                    @a.AgentName
                                </a>
                                @if (!a.IsActive)
                                {
                                    <span class="badge bg-secondary ms-1 small">off</span>
                                }
                            </td>
                            <td><span class="badge bg-secondary small">@(a.AgentType ?? "—")</span></td>
                            <td class="text-center">@StatusBadge(a.Status)</td>
                            <td class="text-muted small">
                                @(a.RunAt.HasValue ? a.RunAt.Value.ToLocalTime().ToString("dd.MM. HH:mm") : "—")
                            </td>
                            <td class="text-muted small">
                                @(a.NextRunAt.HasValue ? a.NextRunAt.Value.ToLocalTime().ToString("dd.MM. HH:mm") : "—")
                            </td>
                            <td class="text-center">
                                @if (overdue)
                                {
                                    <span class="badge @(overdueH > 48 ? "bg-danger" : "bg-warning text-dark")">+@overdueH h</span>
                                }
                                else { <span class="text-muted small">—</span> }
                            </td>
                            <td class="text-muted small">
                                @if (!string.IsNullOrEmpty(a.PromptVersion))
                                {
                                    <span class="badge @(a.PromptVersion == "10.0.0" ? "bg-success" : "bg-warning text-dark")">@a.PromptVersion</span>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-muted small" style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                title="@(a.Highlights ?? a.Summary)">
                                @(a.Highlights ?? a.Summary ?? "")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private List<AgentRow> _agents = new();
    private string _search = string.Empty;
    private string _activeFilter = "Vše";
    private bool _showInactive = false;

    private System.Threading.Timer? _timer;
    private int _refreshCountdown = 300;

    private readonly string[] _filters = ["Vše", "OK", "Chyba", "Blokováni", "Po termínu", "Bez dat"];

    private IEnumerable<AgentRow> FilteredAgents => _agents
        .Where(a => _showInactive || a.IsActive)
        .Where(a => _activeFilter switch
        {
            "OK"         => a.Status == "ok",
            "Chyba"      => a.Status != null && a.Status.Contains("error"),
            "Blokováni"  => a.Status != null && a.Status.Contains("blocked"),
            "Po termínu" => IsOverdue(a),
            "Bez dat"    => a.Status == null,
            _            => true
        })
        .Where(a => string.IsNullOrWhiteSpace(_search) ||
                    a.AgentName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    (a.AgentType ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase));

    private void SetFilter(string f) { _activeFilter = f; }

    private static bool IsOverdue(AgentRow a) =>
        a.IsActive && a.NextRunAt.HasValue && a.NextRunAt.Value < DateTimeOffset.UtcNow;

    private static int OverdueHours(AgentRow a) =>
        a.NextRunAt.HasValue ? (int)(DateTimeOffset.UtcNow - a.NextRunAt.Value).TotalHours : 0;

    private static RenderFragment StatusBadge(string? status) => status switch
    {
        "ok"                                    => @<span class="badge bg-success">✅ ok</span>,
        null                                    => @<span class="badge bg-secondary">??? no data</span>,
        var s when s.Contains("schema_blocked") => @<span class="badge bg-warning text-dark">⛔ schema_blocked</span>,
        var s when s.Contains("blocked")        => @<span class="badge bg-warning text-dark">⚠️ blocked</span>,
        var s when s.Contains("error")          => @<span class="badge bg-danger">❌ error</span>,
        _                                       => @<span class="badge bg-secondary">@status</span>
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _timer = new System.Threading.Timer(async _ =>
        {
            _refreshCountdown--;
            if (_refreshCountdown <= 0)
            {
                _refreshCountdown = 300;
                await LoadAsync();
            }
            await InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private async Task RefreshNow()
    {
        _refreshCountdown = 300;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        await using var db = await DbFactory.CreateDbContextAsync();

        const string sql = """
            SELECT
              s."AgentName",
              s."AgentType",
              s."IntervalHours",
              s."IsActive",
              s."NextRunAt",
              r."RunAt",
              r."Status",
              r."Summary",
              r."Highlights",
              r."Blockers",
              r."Errors",
              r."PromptVersion"
            FROM "AgentSchedules" s
            LEFT JOIN LATERAL (
              SELECT "RunAt","Status","Summary","Highlights","Blockers","Errors","PromptVersion"
              FROM "AgentRunReports"
              WHERE "AgentName" = s."AgentName"
              ORDER BY "RunAt" DESC
              LIMIT 1
            ) r ON true
            WHERE s."IsDeleted" = false
            ORDER BY
              CASE
                WHEN s."IsActive" = false THEN 9
                WHEN r."Status" IS NULL THEN 4
                WHEN r."Status" LIKE '%error%' THEN 0
                WHEN r."Status" LIKE '%blocked%' THEN 1
                WHEN s."NextRunAt" < NOW() THEN 2
                ELSE 3
              END,
              s."NextRunAt" ASC NULLS LAST
            """;

        _agents = await db.Database
            .SqlQueryRaw<AgentRow>(sql)
            .ToListAsync();

        _loading = false;
    }

    public void Dispose() => _timer?.Dispose();

    private class AgentRow
    {
        public string AgentName { get; set; } = "";
        public string? AgentType { get; set; }
        public string? IntervalHours { get; set; }
        public bool IsActive { get; set; }
        public DateTimeOffset? NextRunAt { get; set; }
        public DateTimeOffset? RunAt { get; set; }
        public string? Status { get; set; }
        public string? Summary { get; set; }
        public string? Highlights { get; set; }
        public string? Blockers { get; set; }
        public string? Errors { get; set; }
        public string? PromptVersion { get; set; }
    }
}
