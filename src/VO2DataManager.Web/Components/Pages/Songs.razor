@page "/songs"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using Microsoft.EntityFrameworkCore
@using SharedServices.Models.AiData
@inject IDbContextFactory<AppDbContextAiData> DbFactory
@inject ToastService Toast

<PageTitle>Skladby — VO2 Data Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="m-0"><i class="bi bi-music-note me-2"></i>Skladby</h4>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm">
        <i class="bi bi-plus-lg me-1"></i>Přidat
    </button>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger alert-dismissible" role="alert">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

@if (_showForm)
{
    <div class="card mb-3">
        <div class="card-header">
            <strong>@(_editId.HasValue ? "Upravit skladbu" : "Nová skladba")</strong>
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-5">
                    <label class="form-label small">Název</label>
                    <input class="form-control form-control-sm" @bind="_form.Title" placeholder="Název skladby" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Rok vydání</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ReleaseYear" placeholder="Rok" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Délka (vteřiny)</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.DurationSeconds" placeholder="Délka" />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success btn-sm" @onclick="SaveAsync">
                    <i class="bi bi-check-lg me-1"></i>Uložit
                </button>
                <button class="btn btn-secondary btn-sm" @onclick="HideForm">Zrušit</button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else
{
    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <input class="form-control form-control-sm" placeholder="Hledat skladbu…"
                   @bind="_search" @bind:event="oninput" @bind:after="OnSearchChanged" />
        </div>
        <div class="col-auto">
            <span class="badge bg-secondary">@_total skladeb</span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead class="table-secondary">
                <tr>
                    <th>Název</th>
                    <th>Rok</th>
                    <th>Délka</th>
                    <th style="width:90px">Akce</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _songs)
                {
                    <tr>
                        <td class="fw-semibold">@s.Title</td>
                        <td class="text-muted small">@s.ReleaseYear</td>
                        <td class="text-muted small">@FormatDuration(s.DurationSeconds)</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" title="Upravit"
                                    @onclick="() => ShowEditForm(s)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-danger btn-sm" title="Smazat"
                                    @onclick="() => DeleteAsync(s.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_page == 0)" @onclick="PrevPage">← Předchozí</button>
        <span class="small text-muted">Strana @(_page + 1) (celkem @_total)</span>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_songs.Count < _pageSize)" @onclick="NextPage">Další →</button>
    </div>

    @if (!_songs.Any())
    {
        <p class="text-muted text-center mt-3">Žádné záznamy.</p>
    }
}

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private List<Song> _songs = new();
    private int _page = 0;
    private const int _pageSize = 50;
    private int _total = 0;

    private bool _showForm = false;
    private int? _editId = null;
    private string? _error = null;

    private SongFormModel _form = new();

    private class SongFormModel
    {
        public string? Title { get; set; }
        public int? ReleaseYear { get; set; }
        public int? DurationSeconds { get; set; }
    }

    private static string FormatDuration(int? seconds)
    {
        if (seconds is null) return string.Empty;
        var m = seconds.Value / 60;
        var s = seconds.Value % 60;
        return $"{m}:{s:D2}";
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Songs.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
            query = query.Where(s => s.Title != null && s.Title.Contains(_search));
        _total = await query.CountAsync();
        _songs = await query
            .OrderBy(s => s.Title)
            .Skip(_page * _pageSize)
            .Take(_pageSize)
            .ToListAsync();
        _loading = false;
    }

    private void ShowAddForm()
    {
        _editId = null;
        _form = new SongFormModel();
        _error = null;
        _showForm = true;
    }

    private void ShowEditForm(Song s)
    {
        _editId = s.Id;
        _form = new SongFormModel
        {
            Title = s.Title,
            ReleaseYear = s.ReleaseYear,
            DurationSeconds = s.DurationSeconds
        };
        _error = null;
        _showForm = true;
    }

    private void HideForm()
    {
        _showForm = false;
        _editId = null;
        _error = null;
    }

    private async Task SaveAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (_editId.HasValue)
            {
                var existing = await db.Songs.FindAsync(_editId.Value);
                if (existing != null)
                {
                    existing.Title = _form.Title;
                    existing.ReleaseYear = _form.ReleaseYear;
                    existing.DurationSeconds = _form.DurationSeconds;
                    existing.UpdatedAt = DateTime.UtcNow;
                }
            }
            else
            {
                var song = new Song
                {
                    Title = _form.Title,
                    ReleaseYear = _form.ReleaseYear,
                    DurationSeconds = _form.DurationSeconds,
                    CreatedAt = DateTime.UtcNow,
                    UpdatedAt = DateTime.UtcNow
                };
                db.Songs.Add(song);
            }
            await db.SaveChangesAsync();
            Toast.ShowSuccess("Uloženo", _editId.HasValue ? "Skladba byla úspěšně upravena." : "Skladba byla úspěšně přidána.");
            HideForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Chyba", $"Nepodařilo se uložit: {ex.Message}");
        }
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Songs.FindAsync(id);
            if (existing != null)
            {
                db.Remove(existing);
                await db.SaveChangesAsync();
                Toast.ShowSuccess("Smazáno", "Skladba byla úspěšně smazána.");
            }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Chyba", $"Nepodařilo se smazat: {ex.Message}");
        }
    }

    private async Task OnSearchChanged()
    {
        _page = 0;
        await LoadAsync();
    }

    private async Task PrevPage() { if (_page > 0) { _page--; await LoadAsync(); } }
    private async Task NextPage() { _page++; await LoadAsync(); }
}
