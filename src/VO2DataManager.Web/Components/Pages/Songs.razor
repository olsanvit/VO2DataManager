@page "/songs"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using Microsoft.EntityFrameworkCore
@using SharedServices.Models.AiData
@inject IDbContextFactory<AppDbContextAiData> DbFactory
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Skladby — VO2 Data Manager</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-music-note"></i> Skladby</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-success" @onclick="ExportCsvAsync">
            <i class="bi bi-download me-1"></i>Export CSV
        </button>
        <button class="btn btn-sm btn-primary" @onclick="ShowAddForm">
            <i class="bi bi-plus-lg me-1"></i>Přidat
        </button>
    </div>
</div>

<ConfirmDialog @ref="_confirmDialog" />

<!-- Add / Edit form -->
@if (_showForm)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-@(_editId.HasValue ? "pencil" : "plus-circle") text-accent"></i>
                @(_editId.HasValue ? "Upravit skladbu" : "Nová skladba")
            </span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="HideForm">Zrušit</button>
        </div>
        <div class="p-3">
            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label small text-muted">Název</label>
                    <input class="form-control form-control-sm" @bind="_form.Title" placeholder="Název skladby" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Rok vydání</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ReleaseYear" placeholder="Rok" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Délka (s)</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.DurationSeconds" placeholder="Délka" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="mt-2 text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>@_error</div>
            }
            <div class="mt-3">
                <button class="btn btn-success btn-sm" @onclick="SaveAsync">
                    <i class="bi bi-check-lg me-1"></i>Uložit
                </button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Načítám skladby…</span>
    </div>
}
else
{
    <UiSearchBar @bind-Value="_search" Placeholder="Hledat skladbu…"
                 Count="_total" CountLabel="skladeb"
                 OnSearch="ResetAndLoad" />

    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-music-note text-accent"></i>
                Databáze skladeb
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Název</th>
                        <th class="text-center">Rok</th>
                        <th class="text-center">Délka</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_songs.Any())
                    {
                        <tr><td colspan="4" class="text-muted text-center py-4">Žádné záznamy.</td></tr>
                    }
                    @foreach (var s in _songs)
                    {
                        <tr>
                            <td class="fw-semibold">@s.Title</td>
                            <td class="text-center text-muted small">@s.ReleaseYear</td>
                            <td class="text-center text-muted small">@FormatDuration(s.DurationSeconds)</td>
                            <td class="text-end">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEditForm(s)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(s.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-3 py-2 border-top border-opacity-10">
            <Paginator TotalItems="_total" PageSize="_pageSize" CurrentPage="_page"
                       OnPageChanged="async p => { _page = p; await LoadAsync(); }" />
        </div>
    </div>
}

@code {
    private ConfirmDialog _confirmDialog = default!;
    private int _pendingDeleteId;

    private bool _loading = true;
    private string _search = string.Empty;
    private List<Song> _songs = new();
    private int _page = 1;
    private const int _pageSize = 50;
    private int _total = 0;

    private bool _showForm = false;
    private int? _editId = null;
    private string? _error = null;
    private SongFormModel _form = new();

    private class SongFormModel
    {
        public string? Title { get; set; }
        public int? ReleaseYear { get; set; }
        public int? DurationSeconds { get; set; }
    }

    private static string FormatDuration(int? seconds)
    {
        if (seconds is null) return string.Empty;
        var m = seconds.Value / 60;
        var s = seconds.Value % 60;
        return $"{m}:{s:D2}";
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Songs.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
            query = query.Where(s => s.Title != null && s.Title.Contains(_search));
        _total = await query.CountAsync();
        _songs = await query
            .OrderBy(s => s.Title)
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToListAsync();
        _loading = false;
    }

    private async Task ResetAndLoad() { _page = 1; await LoadAsync(); }

    private void ShowAddForm() { _editId = null; _form = new(); _error = null; _showForm = true; }

    private void ShowEditForm(Song s)
    {
        _editId = s.Id;
        _form = new SongFormModel { Title = s.Title, ReleaseYear = s.ReleaseYear, DurationSeconds = s.DurationSeconds };
        _error = null;
        _showForm = true;
    }

    private void HideForm() { _showForm = false; _editId = null; _error = null; }

    private async Task SaveAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (_editId.HasValue)
            {
                var existing = await db.Songs.FindAsync(_editId.Value);
                if (existing != null)
                {
                    existing.Title = _form.Title;
                    existing.ReleaseYear = _form.ReleaseYear;
                    existing.DurationSeconds = _form.DurationSeconds;
                    existing.UpdatedAt = DateTime.UtcNow;
                }
            }
            else
            {
                db.Songs.Add(new Song
                {
                    Title = _form.Title, ReleaseYear = _form.ReleaseYear,
                    DurationSeconds = _form.DurationSeconds,
                    CreatedAt = DateTime.UtcNow, UpdatedAt = DateTime.UtcNow
                });
            }
            await db.SaveChangesAsync();
            Toast.ShowSuccess("Uloženo", _editId.HasValue ? "Skladba byla upravena." : "Skladba byla přidána.");
            HideForm();
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; Toast.ShowError("Chyba", ex.Message); }
    }

    private async Task ConfirmDelete(int id)
    {
        _pendingDeleteId = id;
        if (await _confirmDialog.ShowAsync("Smazat skladbu", "Opravdu chcete smazat tuto skladbu? Tato akce je nevratná."))
            await DeleteAsync(_pendingDeleteId);
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Songs.FindAsync(id);
            if (existing != null) { db.Remove(existing); await db.SaveChangesAsync(); }
            Toast.ShowSuccess("Smazáno", "Skladba byla odstraněna.");
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; Toast.ShowError("Chyba", ex.Message); }
    }

    private async Task ExportCsvAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var all = await db.Songs.OrderBy(s => s.Title).ToListAsync();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Název,Rok vydání,Délka (s)");
        foreach (var s in all)
            sb.AppendLine($"\"{s.Title?.Replace("\"", "\"\"")}\",{s.ReleaseYear},{s.DurationSeconds}");
        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        await JS.InvokeVoidAsync("downloadBase64File", "skladby.csv", "text/csv", Convert.ToBase64String(bytes));
    }
}
