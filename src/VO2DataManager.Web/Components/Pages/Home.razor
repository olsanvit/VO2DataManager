@page "/"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.EntityFrameworkCore
@using SharedServices.Models.AiData
@inject IDbContextFactory<AppDbContextAiData> DbFactory

<PageTitle>VO2 Data Manager — Dashboard</PageTitle>

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-4">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Načítám data…</span>
    </div>
}
else
{
    <!-- Page header -->
    <div class="ui-page-header ui-anim-fade-up">
        <h3>
            <i class="bi bi-database-fill"></i>
            Dashboard
        </h3>
        <span class="badge bg-secondary text-muted small">VO2 Data Manager</span>
    </div>

    <!-- Stats row -->
    <div class="row g-3 mb-4 ui-anim-fade-up">
        <div class="col-6 col-lg-4">
            <UiStats Label="Interpreti"
                     Value="@_artistCount.ToString("N0")"
                     Icon="bi-music-note-beamed"
                     IconBgClass="icon-accent" />
        </div>
        <div class="col-6 col-lg-4">
            <UiStats Label="Alba"
                     Value="@_albumCount.ToString("N0")"
                     Icon="bi-vinyl"
                     IconBgClass="icon-emerald" />
        </div>
        <div class="col-6 col-lg-4">
            <UiStats Label="Skladby"
                     Value="@_songCount.ToString("N0")"
                     Icon="bi-music-note"
                     IconBgClass="icon-amber" />
        </div>
    </div>

    <!-- Donut chart + quick links -->
    <div class="row g-3 mb-4">
        @if (_total > 0)
        {
            <div class="col-lg-5">
                <div class="ui-panel ui-anim-fade-up">
                    <div class="ui-panel-header">
                        <span class="ui-panel-title">
                            <i class="bi bi-pie-chart-fill text-accent"></i>
                            Poměr obsahu
                        </span>
                    </div>
                    <ApexChart TItem="ChartItem" Options="_chartOptions">
                        <ApexPointSeries TItem="ChartItem"
                                         Items="_chartData"
                                         SeriesType="ApexCharts.SeriesType.Donut"
                                         XValue="@(e => e.Label)"
                                         YValue="@(e => e.Value)" />
                    </ApexChart>
                </div>
            </div>
        }

        <!-- Quick links -->
        <div class="col-lg-7">
            <div class="d-flex flex-column gap-3 ui-anim-fade-up">
                <QuickLinkCard Href="/artists"
                               Icon="bi-music-note-beamed"
                               Title="Interpreti"
                               Description="Správa interpretů a umělců"
                               IconClass="icon-accent" />
                <QuickLinkCard Href="/albums"
                               Icon="bi-vinyl"
                               Title="Alba"
                               Description="Správa hudebních alb"
                               IconClass="icon-emerald" />
                <QuickLinkCard Href="/songs"
                               Icon="bi-music-note"
                               Title="Skladby"
                               Description="Správa skladeb a stop"
                               IconClass="icon-amber" />
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _artistCount;
    private int _albumCount;
    private int _songCount;
    private int _total;

    private List<ChartItem> _chartData = new();

    private readonly ApexChartOptions<ChartItem> _chartOptions = new()
    {
        Legend   = new Legend { Position = LegendPosition.Bottom },
        Chart    = new Chart  { Background = "transparent" },
        Theme    = new ApexCharts.Theme { Mode = Mode.Dark },
        Colors   = ["#6366f1", "#10b981", "#f59e0b"]
    };

    private class ChartItem
    {
        public string Label { get; set; } = string.Empty;
        public decimal Value { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _artistCount = await db.Artists.CountAsync();
        _albumCount  = await db.Albums.CountAsync();
        _songCount   = await db.Songs.CountAsync();
        _total = _artistCount + _albumCount + _songCount;

        _chartData = new List<ChartItem>
        {
            new() { Label = "Interpreti", Value = _artistCount },
            new() { Label = "Alba",       Value = _albumCount  },
            new() { Label = "Skladby",    Value = _songCount   },
        };

        _loading = false;
    }
}
