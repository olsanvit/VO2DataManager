@page "/artists"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using Microsoft.EntityFrameworkCore
@using SharedServices.Models.AiData
@inject IDbContextFactory<AppDbContextAiData> DbFactory
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Interpreti — VO2 Data Manager</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-music-note-beamed"></i> Interpreti</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-success" @onclick="ExportCsvAsync">
            <i class="bi bi-download me-1"></i>Export CSV
        </button>
        <button class="btn btn-sm btn-primary" @onclick="ShowAddForm">
            <i class="bi bi-plus-lg me-1"></i>Přidat
        </button>
    </div>
</div>

<ConfirmDialog @ref="_confirmDialog" />

<!-- Add / Edit form -->
@if (_showForm)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-@(_editId.HasValue ? "pencil" : "plus-circle") text-accent"></i>
                @(_editId.HasValue ? "Upravit interpreta" : "Nový interpret")
            </span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="HideForm">Zrušit</button>
        </div>
        <div class="p-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Název</label>
                    <input class="form-control form-control-sm" @bind="_form.Name" placeholder="Název interpreta" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">Sort Name</label>
                    <input class="form-control form-control-sm" @bind="_form.SortName" placeholder="Sort name" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Aktivní od</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ActiveFromYear" placeholder="Rok" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Aktivní do</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ActiveToYear" placeholder="Rok" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Skóre</label>
                    <input type="number" class="form-control form-control-sm" @bind="_form.ConfidenceScore" placeholder="Skóre" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted">Webová stránka</label>
                    <input class="form-control form-control-sm" @bind="_form.OfficialWebsiteUrl" placeholder="https://…" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">GuidId</label>
                    <input class="form-control form-control-sm" @bind="_form.GuidId" placeholder="GUID" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="mt-2 text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>@_error</div>
            }
            <div class="mt-3">
                <button class="btn btn-success btn-sm" @onclick="SaveAsync">
                    <i class="bi bi-check-lg me-1"></i>Uložit
                </button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Načítám interprety…</span>
    </div>
}
else
{
    <UiSearchBar @bind-Value="_search" Placeholder="Hledat interpreta…"
                 Count="_total" CountLabel="interpretů"
                 OnSearch="ResetAndLoad" />

    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-music-note-beamed text-accent"></i>
                Databáze interpretů
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Název</th>
                        <th>Sort Name</th>
                        <th class="text-center">Od</th>
                        <th class="text-center">Do</th>
                        <th class="text-center">Skóre</th>
                        <th class="text-center">Web</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_artists.Any())
                    {
                        <tr><td colspan="7" class="text-muted text-center py-4">Žádné záznamy.</td></tr>
                    }
                    @foreach (var a in _artists)
                    {
                        <tr>
                            <td class="fw-semibold">@a.Name</td>
                            <td class="text-muted small">@a.SortName</td>
                            <td class="text-center text-muted small">@a.ActiveFromYear</td>
                            <td class="text-center text-muted small">@a.ActiveToYear</td>
                            <td class="text-center"><span class="badge bg-secondary">@a.ConfidenceScore</span></td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(a.OfficialWebsiteUrl))
                                {
                                    <a href="@a.OfficialWebsiteUrl" target="_blank" rel="noopener noreferrer" class="text-accent">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEditForm(a)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(a.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-3 py-2 border-top border-opacity-10">
            <Paginator TotalItems="_total" PageSize="_pageSize" CurrentPage="_page"
                       OnPageChanged="async p => { _page = p; await LoadAsync(); }" />
        </div>
    </div>
}

@code {
    private ConfirmDialog _confirmDialog = default!;
    private int _pendingDeleteId;

    private bool _loading = true;
    private string _search = string.Empty;
    private List<Artist> _artists = new();
    private int _page = 1;
    private const int _pageSize = 50;
    private int _total = 0;

    private bool _showForm = false;
    private int? _editId = null;
    private string? _error = null;
    private ArtistFormModel _form = new();

    private class ArtistFormModel
    {
        public string? Name { get; set; }
        public string? SortName { get; set; }
        public int? ActiveFromYear { get; set; }
        public int? ActiveToYear { get; set; }
        public int? ConfidenceScore { get; set; }
        public string? OfficialWebsiteUrl { get; set; }
        public string? GuidId { get; set; }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Artists.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
            query = query.Where(a => a.Name != null && a.Name.Contains(_search));
        _total = await query.CountAsync();
        _artists = await query
            .OrderBy(a => a.SortName ?? a.Name)
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToListAsync();
        _loading = false;
    }

    private async Task ResetAndLoad() { _page = 1; await LoadAsync(); }

    private void ShowAddForm() { _editId = null; _form = new(); _error = null; _showForm = true; }

    private void ShowEditForm(Artist a)
    {
        _editId = a.Id;
        _form = new ArtistFormModel
        {
            Name = a.Name, SortName = a.SortName,
            ActiveFromYear = a.ActiveFromYear, ActiveToYear = a.ActiveToYear,
            ConfidenceScore = a.ConfidenceScore, OfficialWebsiteUrl = a.OfficialWebsiteUrl,
            GuidId = a.GuidId
        };
        _error = null;
        _showForm = true;
    }

    private void HideForm() { _showForm = false; _editId = null; _error = null; }

    private async Task SaveAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (_editId.HasValue)
            {
                var existing = await db.Artists.FindAsync(_editId.Value);
                if (existing != null)
                {
                    existing.Name = _form.Name; existing.SortName = _form.SortName;
                    existing.ActiveFromYear = _form.ActiveFromYear; existing.ActiveToYear = _form.ActiveToYear;
                    existing.ConfidenceScore = _form.ConfidenceScore;
                    existing.OfficialWebsiteUrl = _form.OfficialWebsiteUrl; existing.GuidId = _form.GuidId;
                }
            }
            else
            {
                db.Artists.Add(new Artist
                {
                    Name = _form.Name, SortName = _form.SortName,
                    ActiveFromYear = _form.ActiveFromYear, ActiveToYear = _form.ActiveToYear,
                    ConfidenceScore = _form.ConfidenceScore,
                    OfficialWebsiteUrl = _form.OfficialWebsiteUrl, GuidId = _form.GuidId
                });
            }
            await db.SaveChangesAsync();
            Toast.ShowSuccess("Uloženo", _editId.HasValue ? "Interpret byl upraven." : "Interpret byl přidán.");
            HideForm();
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; Toast.ShowError("Chyba", ex.Message); }
    }

    private async Task ConfirmDelete(int id)
    {
        _pendingDeleteId = id;
        if (await _confirmDialog.ShowAsync("Smazat interpreta", "Opravdu chcete smazat tohoto interpreta? Tato akce je nevratná."))
            await DeleteAsync(_pendingDeleteId);
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.Artists.FindAsync(id);
            if (existing != null) { db.Remove(existing); await db.SaveChangesAsync(); }
            Toast.ShowSuccess("Smazáno", "Interpret byl odstraněn.");
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; Toast.ShowError("Chyba", ex.Message); }
    }

    private async Task ExportCsvAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var all = await db.Artists.OrderBy(a => a.SortName ?? a.Name).ToListAsync();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Název,Sort Name,Aktivní od,Aktivní do,Skóre,Web");
        foreach (var a in all)
            sb.AppendLine($"\"{a.Name?.Replace("\"", "\"\"")}\",\"{a.SortName?.Replace("\"", "\"\"")}\",{a.ActiveFromYear},{a.ActiveToYear},{a.ConfidenceScore},\"{a.OfficialWebsiteUrl?.Replace("\"", "\"\"")}\"");
        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        await JS.InvokeVoidAsync("downloadBase64File", "interpreti.csv", "text/csv", Convert.ToBase64String(bytes));
    }
}
