@* AUDIT:OK *@
@page "/admin/projects"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer

<PageTitle>Přehled projektů</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h4 class="m-0"><i class="bi bi-grid-3x3-gap me-2 text-accent"></i>Přehled projektů</h4>
</div>

<div class="row g-3 ui-anim-fade-up">
    @foreach (var p in _projects)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="ui-panel h-100">
                <div class="ui-panel-header d-flex justify-content-between align-items-center">
                    <span class="ui-panel-title">
                        <i class="bi @p.Icon text-accent me-1"></i>@p.Name
                    </span>
                    <span class="badge @p.StatusClass small">@p.Status</span>
                </div>
                <div class="p-3">
                    <p class="text-muted small mb-2">@p.Description</p>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (!string.IsNullOrEmpty(p.ProdUrl))
                        {
                            <a href="@p.ProdUrl" target="_blank" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-box-arrow-up-right me-1"></i>Produkce
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(p.DevUrl))
                        {
                            <a href="@p.DevUrl" target="_blank" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-code-slash me-1"></i>Dev
                            </a>
                        }
                        <a href="@p.GitHubUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-github me-1"></i>GitHub
                        </a>
                    </div>
                    @if (p.Notes.Length > 0)
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var note in p.Notes)
                            {
                                <li class="small text-muted"><i class="bi bi-dot"></i>@note</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    }
</div>

