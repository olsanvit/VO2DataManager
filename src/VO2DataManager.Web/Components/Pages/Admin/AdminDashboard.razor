@page "/admin"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@using MercenariesAndBeasts.Infrastructure
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SharedServices.Models.AiData
@inject UserManager<AppUser> UserManager
@inject IDbContextFactory<AppDbContextAiData> DbFactory

<PageTitle>Admin — VO2DataManager</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h4 class="m-0"><i class="bi bi-shield-lock me-2 text-accent"></i>Admin — VO2DataManager</h4>
</div>

@if (_loading)
{
    <PageLoadingSpinner />
}
else
{
    <!-- Statistiky -->
    <div class="row g-3 mb-3 ui-anim-fade-up">
        <div class="col-6 col-md-2">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-accent">@_userCount</div>
                <div class="text-muted small">Uživatelé</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-accent">@_artistCount</div>
                <div class="text-muted small">Interpreti</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-accent">@_albumCount</div>
                <div class="text-muted small">Alba</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-accent">@_songCount</div>
                <div class="text-muted small">Skladby</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-accent">@_amFootballLeagueCount</div>
                <div class="text-muted small">Am.Football ligy</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-accent">@_baseballLeagueCount</div>
                <div class="text-muted small">Baseball ligy</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Uživatelé -->
        <div class="col-md-4">
            <div class="ui-panel h-100 ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-people text-accent"></i>Uživatelé (@_userCount)
                    </span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Email</th><th>Role</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _users)
                            {
                                <tr>
                                    <td class="small">@u.Email</td>
                                    <td>
                                        @if (u.IsAdmin)
                                        { <span class="badge bg-warning text-dark">Admin</span> }
                                        else
                                        { <span class="badge bg-secondary">User</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Top interpreti -->
        <div class="col-md-8">
            <div class="ui-panel h-100 ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-music-note-list text-accent"></i>Top 20 interpretů (dle abecedy)
                    </span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Interpret</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _recentArtists)
                            {
                                <tr>
                                    <td class="small">@a.Name</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Přehled AI dat -->
    <div class="ui-panel ui-anim-fade-up mt-3">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-database text-accent"></i>Přehled AI dat
            </span>
        </div>
        <div class="p-3">
            <div class="row g-2 text-center">
                <div class="col-6 col-md-3">
                    <div class="fs-5 fw-bold text-accent">@_artistCount</div>
                    <div class="text-muted small">Interpreti</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-5 fw-bold text-accent">@_albumCount</div>
                    <div class="text-muted small">Alba</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-5 fw-bold text-accent">@_songCount</div>
                    <div class="text-muted small">Skladby</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-5 fw-bold text-accent">@_amFootballLeagueCount</div>
                    <div class="text-muted small">Am.Football ligy</div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _userCount, _artistCount, _albumCount, _songCount, _amFootballLeagueCount, _baseballLeagueCount;
    private List<AppUser> _users = new();
    private List<Artist> _recentArtists = new();

    protected override async Task OnInitializedAsync()
    {
        _users = UserManager.Users.OrderByDescending(u => u.IsAdmin).ToList();
        _userCount = _users.Count;

        await using var db = await DbFactory.CreateDbContextAsync();
        _artistCount           = await db.Artists.CountAsync();
        _albumCount            = await db.Albums.CountAsync();
        _songCount             = await db.Songs.CountAsync();
        _amFootballLeagueCount = await db.AmericanFootballLeagues.CountAsync();
        _baseballLeagueCount   = await db.BaseballLeagues.CountAsync();

        _recentArtists = await db.Artists
            .OrderBy(a => a.Name)
            .Take(20)
            .ToListAsync();

        _loading = false;
    }
}
