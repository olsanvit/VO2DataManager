@page "/amfootball"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using Microsoft.EntityFrameworkCore
@using SharedServices.Models.AiData
@inject IDbContextFactory<AppDbContextAiData> DbFactory

<PageTitle>Americký fotbal — VO2 Data Manager</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-trophy me-2"></i>Americký fotbal</h3>
</div>

@if (_loading)
{
    <PageLoadingSpinner />
}
else
{
    <!-- Tabs -->
    <div class="d-flex gap-2 mb-3 ui-anim-fade-up">
        <button class="btn btn-sm @(_tab == 0 ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetTab(0)'>
            <i class="bi bi-people me-1"></i>Týmy
        </button>
        <button class="btn btn-sm @(_tab == 1 ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetTab(1)'>
            <i class="bi bi-diagram-3 me-1"></i>Ligy
        </button>
        <button class="btn btn-sm @(_tab == 2 ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetTab(2)'>
            <i class="bi bi-calendar3 me-1"></i>Sezóny
        </button>
    </div>

    @if (_tab == 0)
    {
        <div class="ui-panel ui-anim-fade-up">
            <div class="ui-panel-header">
                <span class="ui-panel-title">
                    <i class="bi bi-people text-accent"></i>
                    Týmy
                </span>
                <span class="badge bg-secondary">@FilteredTeams.Count()</span>
            </div>
            <div class="px-3 pt-3">
                <UiSearchBar @bind-Value="_search"
                             Placeholder="Hledat tým…"
                             Count="@FilteredTeams.Count()"
                             CountLabel="týmů" />
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Název</th>
                            <th>Norm. název</th>
                            <th>Zdroj</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in FilteredTeams.Take(100))
                        {
                            <tr>
                                <td class="fw-semibold">@t.Name</td>
                                <td class="text-muted small">@t.NormalizedName</td>
                                <td class="text-muted small">@t.ExternalSource</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (_tab == 1)
    {
        <div class="ui-panel ui-anim-fade-up">
            <div class="ui-panel-header">
                <span class="ui-panel-title">
                    <i class="bi bi-diagram-3 text-accent"></i>
                    Ligy
                </span>
                <span class="badge bg-secondary">@_leagues.Count</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Název</th>
                            <th>Norm. název</th>
                            <th>Zdroj</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in _leagues)
                        {
                            <tr>
                                <td class="fw-semibold">@l.Name</td>
                                <td class="text-muted small">@l.NormalizedName</td>
                                <td class="text-muted small">@l.ExternalSource</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="ui-panel ui-anim-fade-up">
            <div class="ui-panel-header">
                <span class="ui-panel-title">
                    <i class="bi bi-calendar3 text-accent"></i>
                    Sezóny
                </span>
                <span class="badge bg-secondary">@_seasons.Count</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Název</th>
                            <th>Norm. název</th>
                            <th>Zdroj</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _seasons)
                        {
                            <tr>
                                <td class="fw-semibold">@s.Name</td>
                                <td class="text-muted small">@s.NormalizedName</td>
                                <td class="text-muted small">@s.ExternalSource</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private bool _loading = true;
    private int _tab = 0;
    private string _search = string.Empty;

    private List<AmericanFootballTeam> _teams = new();
    private List<AmericanFootballLeague> _leagues = new();
    private List<AmericanFootballSeason> _seasons = new();

    private IEnumerable<AmericanFootballTeam> FilteredTeams => string.IsNullOrWhiteSpace(_search)
        ? _teams
        : _teams.Where(t => t.Name != null && t.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _teams   = await db.AmericanFootballTeams.OrderBy(t => t.Name).ToListAsync();
        _leagues = await db.AmericanFootballLeagues.OrderBy(l => l.Name).ToListAsync();
        _seasons = await db.AmericanFootballSeasons.OrderBy(s => s.Name).ToListAsync();
        _loading = false;
    }

    private void SetTab(int tab) { _tab = tab; _search = string.Empty; }
}
