@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4 py-3">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <div class="alert alert-danger m-3" role="alert">
                        <h4 class="alert-heading">Nastala chyba</h4>
                        <p>Při zpracování požadavku nastala neočekávaná chyba. Zkuste obnovit stránku.</p>
                        <hr />
                        <p class="mb-0 text-muted small">@ex.Message</p>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>

<Toast />
<LoadingOverlay />
<BlazoredModal />

<div id="blazor-error-ui" data-nosnippet>
    Nastala neočekávaná chyba.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">×</span>
</div>
