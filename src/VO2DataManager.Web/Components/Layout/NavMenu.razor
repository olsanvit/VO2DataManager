@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">
            <i class="bi bi-database-fill me-2"></i>VO2 Data Manager
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door me-2"></i> Dashboard
                    </NavLink>
                </div>
                @* Hudební modul (Artists/Albums/Songs) skryt — tabulky v produkční DB zatím neexistují, viz Home.razor *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/amfootball">
                        <i class="bi bi-trophy me-2"></i> Am. fotbal
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/basketball">
                        <i class="bi bi-dribbble me-2"></i> Basketbal
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/music-dashboard">
                        <i class="bi bi-music-note-list me-2"></i> Hudba — přehled
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/search">
                        <i class="bi bi-search me-2"></i> Hledání
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/achievements">
                        <i class="bi bi-trophy-fill me-2"></i> Achievementy
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/agents">
                        <i class="bi bi-robot me-2"></i> Agenti
                    </NavLink>
                </div>

                <AuthorizeView Roles="Admin" Context="adminCtx">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="/admin">
                                <i class="bi bi-shield-lock me-2"></i> Admin
                            </NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="/admin/audit">
                                <i class="bi bi-clipboard2-check me-2"></i> Audit projektů
                            </NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="/admin/projects">
                                <i class="bi bi-grid-3x3-gap me-2"></i> Přehled projektů
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <hr class="nav-divider" />

                <div class="nav-item px-3">
                    <a class="nav-link nav-link-external" href="https://vo2info.cz/prehled" target="_blank">
                        <i class="bi bi-grid me-2"></i> vo2info — přehled
                    </a>
                </div>

                <hr class="nav-divider" />

                <div class="nav-item px-3">
                    <span class="nav-link text-muted small">
                        <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                    </span>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="/logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Odhlásit
                    </a>
                </div>
                <ThemePicker />
                <LangSwitcher />
                <UiLibrarySwitcher />
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Přihlásit
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/register">
                        <i class="bi bi-person-plus me-2"></i> Registrace
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

<style>
    .nav-divider {
        border-color: rgba(255,255,255,.15);
        margin: .5rem 1rem;
    }
    .nav-link-external {
        font-size: .8rem;
        opacity: .55;
    }
    .nav-link-external:hover { opacity: .9; }
</style>
